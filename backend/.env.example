# Environment Variables
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/schoolpulse?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000,https://*.pulseschools.com,https://pulseschools.com"

# Redis (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="noreply@pulseschools.com"

# AWS Configuration (for production)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET="school-pulse-uploads"
RDS_HOST="your-rds-endpoint.rds.amazonaws.com"
RDS_PORT=5432
RDS_DATABASE="schoolpulse"
RDS_USERNAME="postgres"
RDS_PASSWORD="your-rds-password"

# Feature Flags
FEATURE_REGISTRATION=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_BILLING=true
FEATURE_SMS_NOTIFICATIONS=false
